{"jsonrpc":"2.0","method":"textDocument/didOpen","params":{"textDocument":{"uri":"file:///root/workspace/cangjie/test_projects/Derive/src/main.cj","languageId":"Cangjie","version":1,"text":"// Copyright (c) Huawei Technologies Co., Ltd. 2026. All rights reserved.\n// This source file is part of the Cangjie project, licensed under Apache-2.0\n// with Runtime Library Exception.\n//\n// See https://cangjie-lang.cn/pages/LICENSE for license information.\n\npackage Derive\n\nimport std.deriving.*\n\n@Derive[Equatable]\nenum A {\n    | B\n}\n\n@Derive[Equatable]\nenum D {\n    | E\n}\n\n@Derive[Equatable] // 注释后无报错\nstruct C {\n    let a: A\n    let d: D\n    init(a: A) {\n        this.a = a\n        this.d = E\n    }\n    init(d: D) {\n        this.a = B\n        this.d = d\n    }\n}\n\nfunc foo(a: A) {}\n\nmain(): Int64 {\n    C(B)\n    C(E)\n    foo(B)\n    return 0\n}"}}}

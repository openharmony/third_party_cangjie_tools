{"jsonrpc": "2.0", "method": "textDocument/didOpen", "params": {"textDocument": {"uri": "file:///d%3A/Work/repo/Char/NewVersion/cangjie_language_server/test/testChr/normalTest/PatternMatch/src/variablePattern/variablePattern.cj", "languageId": "Cangjie", "version": 1, "text": "// Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.\n// This source file is part of the Cangjie project, licensed under Apache-2.0\n// with Runtime Library Exception.\n//\n// See https://cangjie-lang.cn/pages/LICENSE for license information.\n\npackage default.variablePattern\nfunc testVariablePattern() {\n    let score: Int64 = 90\n    let PASS = 60\n    let Full1 = 100\n\n    /**\n    * this is good\n    */\n    let good = 70\n    var scoreResult: String = match (score) {\n        case PASS => \"pass\" // constant pattern.\n        case Full1 => \"Full\" // ok, but not recommend.\n        case good => \"good\" /* matched. warning: 'good' has been defined outside the match expression,\n                            are you sure using 'good' as a variable pattern here ?*/\n    }\n    func test() {\n        let score: Int64 = 90\n        var scoreResult: Int64 = match (score) {\n        case 60 => 60\n        case 70 | 80 => 80\n        case 90 | 100 => 100 // matched\n        case failScore => // variable pattern\n        let passNeed = 60 - failScore\n        passNeed\n        }\n    }\n}"}}}
